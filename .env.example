# ReadRoom — Environment Variables
# Copy this file to .env.local and fill in your keys
# NEVER commit .env.local

# Deepgram API Key — get from https://console.deepgram.com
DEEPGRAM_API_KEY=

# Anthropic API Key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Redis URL — get from Redis Cloud (redis.io/try-free) or your local instance
REDIS_URL=
